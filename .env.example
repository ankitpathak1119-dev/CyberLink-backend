NODE_ENV=development
PORT=4000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/cyberlink?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_very_strong_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Firebase Admin (for FCM push notifications)
# Option A: full JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: individual fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
